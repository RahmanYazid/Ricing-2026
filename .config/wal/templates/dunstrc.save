d[global]
    font = JetBrainsMono Nerd Font 10
    origin = top-right
    offset = 10x10
    width = 300
    height = 100
    timeout = 5

[urgency_normal]
    background = "{color0}"
    foreground = "{foreground}"
    frame_color = "{color4}"
    timeout = 5

[urgency_low]
    background = "{color0}"
    foreground = "{foreground}"
    frame_color = "{color2}"
    timeout = 3

[urgency_critical]
    background = "{color1}"
    foreground = "{foreground}"
    frame_color = "{color3}"
    timeout = 0
